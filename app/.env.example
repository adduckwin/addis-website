# Cloudinary Configuration
# Получите значения на https://cloudinary.com/console

# 1. Зарегистрируйтесь на Cloudinary (бесплатно)
# 2. В Dashboard скопируйте Cloud Name
# 3. Создайте Upload Preset: Settings → Upload → Upload presets → Add upload preset
#    - Signing Mode: Unsigned
#    - Folder: addis (или любой другой)
#    - Сохраните и скопируйте Upload preset name

VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset

# Опционально (для удаления изображений):
# В продакшене лучше использовать серверную часть для удаления
VITE_CLOUDINARY_API_KEY=
VITE_CLOUDINARY_API_SECRET=
